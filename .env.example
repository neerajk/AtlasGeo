# Copy to .env and fill in your keys.
# At minimum, set ONE of: OPENROUTER_API_KEY (free models available) or ANTHROPIC_API_KEY.

# --- LLM Keys (at least one required) ---
OPENROUTER_API_KEY=          # https://openrouter.ai — free models available
ANTHROPIC_API_KEY=           # claude-sonnet / opus
OPENAI_API_KEY=              # gpt-4o etc.
GOOGLE_API_KEY=              # gemini-2.0-flash (free tier)
GROQ_API_KEY=                # llama3 on groq (fast, free tier)

# --- Model overrides (optional, override config/models.yaml per-agent) ---
# ATLAS_MODEL_PLANNER=anthropic/claude-sonnet-4-6
# ATLAS_MODEL_STAC_SCOUT=openrouter/google/gemini-2.0-flash-exp:free
# ATLAS_MODEL_RESPONSE=openrouter/meta-llama/llama-3.3-70b-instruct:free

# --- App ---
DEBUG=false
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
